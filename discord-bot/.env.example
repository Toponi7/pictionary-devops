# ── Discord ───────────────────────────────────────────────────────────────────
# Discord Developer Portal → ton application → Bot → Reset Token
DISCORD_TOKEN=ton_token_discord_ici

# ID de ton serveur Discord
# Discord → Paramètres → Avancé → Mode développeur ON
# Clic droit sur ton serveur → Copier l'identifiant
DISCORD_GUILD_ID=ton_guild_id_ici

# ── GitHub ────────────────────────────────────────────────────────────────────
# GitHub → Settings → Developer settings → Personal access tokens
# Scope requis : Actions (read & write)
GITHUB_TOKEN=ton_pat_github_ici
GITHUB_REPO=Toponi7/pictionary-devops

# ── OpenStack / OVH ───────────────────────────────────────────────────────────
# Identifiants OVH (les mêmes que dans les secrets GitHub)
OS_USERNAME=ton_username_ovh
OS_PASSWORD=ton_password_ovh

# Project ID OVH : visible dans main.tf (tenant_id)
OS_PROJECT_ID=ac782cb2bd6442dfa69ced8526c8a095

# Région OVH (BHS5, GRA11, SBG5, etc.)
OS_REGION=BHS5

# URL d'auth OVH (ne pas modifier)
OS_AUTH_URL=https://auth.cloud.ovh.net/v3
